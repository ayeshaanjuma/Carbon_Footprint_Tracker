# Server Configuration
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Database Configuration (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
